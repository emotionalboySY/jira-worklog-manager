{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JiraWorklogWidget",
  "version": "0.2.0",
  "identifier": "com.jiraworklog.widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Jira 업무 기록 위젯",
        "width": 300,
        "height": 150,
        "minWidth": 200,
        "minHeight": 150,
        "maxHeight": 150,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "maximizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/emotionalboySY/jira-worklog-widget-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1MjE2REExQkUyNjkxRQpSV1FlYWVJYjJoWlNESjIzOWpmNDRyZTVkSEU2K2ZpUExpeGdTemtxSXpuYmc4U2xRQlhOU09NUQo="
    }
  }
}
