# Atlassian OAuth 2.0 (3LO) 설정
# developer.atlassian.com > 앱 > Settings 에서 확인
VITE_ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# (선택) 서버 측 라우트에서만 쓰는 클라이언트 ID 별칭. 미설정 시 VITE_ATLASSIAN_CLIENT_ID 사용
# ATLASSIAN_CLIENT_ID=

# (선택, 권장) CORS 화이트리스트 — 쉼표로 구분된 origin 목록.
# 미설정 시 같은 호스트의 origin만 허용 (자기 자신 호출만 허용).
# 예: ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
# ALLOWED_ORIGINS=
